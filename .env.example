# Optional local LLM (Ollama) configuration.
#
# The assistant runs fully without any LLM: when no Ollama daemon is reachable it
# falls back to deterministic, template-based drafting (the active mode is shown in
# the UI Trust/Audit panels). To enable a local model, start `ollama serve` and
# pull a model, then copy this file to `.env`.
#
#   ollama pull qwen2.5:7b
#   ollama serve

# Model to use for response drafting (default: qwen2.5:7b).
OLLAMA_MODEL=qwen2.5:7b

# Bound the request so a slow local model can't stall the investigation; it falls
# back to the deterministic template if it exceeds these limits.
OLLAMA_TIMEOUT_S=20
OLLAMA_MAX_TOKENS=200
